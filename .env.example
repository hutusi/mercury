# Required: Postgres connection string.
# Local dev (docker-compose): postgresql://mercury:mercury@localhost:5432/mercury
# Production: Neon's *pooled* connection string (includes ?sslmode=require).
DATABASE_URL=

# Required: secret for better-auth session signing (generate: openssl rand -base64 32)
BETTER_AUTH_SECRET=

# Base URL of the app (used by better-auth). Production: your real domain.
BETTER_AUTH_URL=http://localhost:3000

# Optional: enables AI feedback for writing & speaking. Configure either provider;
# when both are set, Claude wins unless MERCURY_AI_PROVIDER pins one.
# When neither is set, the app falls back to model answers + self-assessment checklists.
ANTHROPIC_API_KEY=
DASHSCOPE_API_KEY=

# Optional: pin the AI provider explicitly ("anthropic" or "bailian").
MERCURY_AI_PROVIDER=

# Optional: override the active provider's default model
# (anthropic: claude-sonnet-5, bailian: glm-5.2). Provider-specific — clear it
# when switching providers.
MERCURY_AI_MODEL=

# Optional: Bailian OpenAI-compatible endpoint override
# (default: https://dashscope.aliyuncs.com/compatible-mode/v1; use
# https://dashscope-intl.aliyuncs.com/compatible-mode/v1 outside mainland China).
DASHSCOPE_BASE_URL=

# Optional: per-user daily message cap for the AI tutor chat (default 30).
MERCURY_CHAT_DAILY_LIMIT=
