# Required: secret for better-auth session signing (generate: openssl rand -base64 32)
BETTER_AUTH_SECRET=

# Base URL of the app (used by better-auth)
BETTER_AUTH_URL=http://localhost:3000

# Optional: enables AI feedback for writing & speaking.
# When unset, the app falls back to model answers + self-assessment checklists.
ANTHROPIC_API_KEY=

# Optional: override the Claude model used for feedback (default: claude-sonnet-5)
MERCURY_AI_MODEL=
