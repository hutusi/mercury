{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "array",
  "items": {
    "type": "object",
    "properties": {
      "id": {
        "type": "string"
      },
      "track": {
        "type": "string",
        "enum": ["toeic", "ielts", "business"]
      },
      "title": {
        "type": "string"
      },
      "titleZh": {
        "type": "string"
      },
      "genre": {
        "type": "string"
      },
      "passage": {
        "type": "string"
      },
      "suggestedMinutes": {
        "type": "integer",
        "exclusiveMinimum": 0,
        "maximum": 9007199254740991
      },
      "questions": {
        "minItems": 1,
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string"
            },
            "stem": {
              "type": "string"
            },
            "options": {
              "minItems": 4,
              "maxItems": 4,
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "correctIndex": {
              "type": "integer",
              "minimum": 0,
              "maximum": 3
            },
            "explanationZh": {
              "type": "string"
            }
          },
          "required": ["id", "stem", "options", "correctIndex", "explanationZh"],
          "additionalProperties": false
        }
      }
    },
    "required": [
      "id",
      "track",
      "title",
      "titleZh",
      "genre",
      "passage",
      "suggestedMinutes",
      "questions"
    ],
    "additionalProperties": false
  }
}
