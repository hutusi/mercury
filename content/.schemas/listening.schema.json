{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "array",
  "items": {
    "type": "object",
    "properties": {
      "id": {
        "type": "string"
      },
      "track": {
        "type": "string",
        "enum": ["toeic", "ielts", "business"]
      },
      "title": {
        "type": "string"
      },
      "titleZh": {
        "type": "string"
      },
      "style": {
        "type": "string"
      },
      "script": {
        "minItems": 1,
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "speaker": {
              "type": "string",
              "enum": ["A", "B", "narrator"]
            },
            "text": {
              "type": "string"
            }
          },
          "required": ["speaker", "text"],
          "additionalProperties": false
        }
      },
      "questions": {
        "minItems": 1,
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string"
            },
            "stem": {
              "type": "string"
            },
            "options": {
              "minItems": 4,
              "maxItems": 4,
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "correctIndex": {
              "type": "integer",
              "minimum": 0,
              "maximum": 3
            },
            "explanationZh": {
              "type": "string"
            }
          },
          "required": ["id", "stem", "options", "correctIndex", "explanationZh"],
          "additionalProperties": false
        }
      }
    },
    "required": ["id", "track", "title", "titleZh", "style", "script", "questions"],
    "additionalProperties": false
  }
}
