{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "id": {
      "type": "string"
    },
    "track": {
      "type": "string",
      "enum": ["toeic", "ielts"]
    },
    "title": {
      "type": "string"
    },
    "titleZh": {
      "type": "string"
    },
    "descriptionZh": {
      "type": "string"
    },
    "sections": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "kind": {
            "type": "string",
            "enum": ["listening", "reading"]
          },
          "title": {
            "type": "string"
          },
          "titleZh": {
            "type": "string"
          },
          "durationSeconds": {
            "type": "integer",
            "exclusiveMinimum": 0,
            "maximum": 9007199254740991
          },
          "groups": {
            "minItems": 1,
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                },
                "passage": {
                  "type": "string"
                },
                "script": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "speaker": {
                        "type": "string",
                        "enum": ["A", "B", "narrator"]
                      },
                      "text": {
                        "type": "string"
                      }
                    },
                    "required": ["speaker", "text"],
                    "additionalProperties": false
                  }
                },
                "questions": {
                  "minItems": 1,
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": {
                        "type": "string"
                      },
                      "stem": {
                        "type": "string"
                      },
                      "options": {
                        "minItems": 4,
                        "maxItems": 4,
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      },
                      "correctIndex": {
                        "type": "integer",
                        "minimum": 0,
                        "maximum": 3
                      },
                      "explanationZh": {
                        "type": "string"
                      }
                    },
                    "required": ["id", "stem", "options", "correctIndex", "explanationZh"],
                    "additionalProperties": false
                  }
                }
              },
              "required": ["id", "questions"],
              "additionalProperties": false
            }
          }
        },
        "required": ["id", "kind", "title", "titleZh", "durationSeconds", "groups"],
        "additionalProperties": false
      }
    }
  },
  "required": ["id", "track", "title", "titleZh", "descriptionZh", "sections"],
  "additionalProperties": false
}
